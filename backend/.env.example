PROJECT_NAME=Martyrs Archive API
API_V1_PREFIX=/api/v1
APP_ENV=development

# Neon compatible; plain postgresql:// URLs are auto-normalized to asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/martyrs_archive
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=http://localhost:3000

# Cloudinary (required when APP_ENV=production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=martyrs-archive
ALLOW_LOCAL_MEDIA_FALLBACK=true

# Local fallback media storage (used when Cloudinary values are empty)
MEDIA_BASE_URL=http://localhost:8000
LOCAL_MEDIA_DIR=media

MAX_IMAGE_SIZE_MB=5
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
